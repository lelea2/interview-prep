{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@interview-prep/shared": ["../shared/types.ts"]
    }
  },
  "include": ["src/**/*", "../shared/types.ts"],
  "exclude": ["node_modules", "dist"]
}
